---
import MainBackground from '../assets/MainBackground.svg';
import HomePageDesign from '../assets/HomePageDesign.png';
import HPGrayDesign from '../assets/HPGrayDesign.png';
import learnarrow from '../assets/learnarrow.png';
import card1design from '../assets/card1design.png';
import card2design from '../assets/card2design.png';

---
<head>
  <link rel="stylesheet" href="https://use.typekit.net/wiz5trz.css">
</head>

<div id="container">
	<img id="MainBackground" src={MainBackground.src} alt="" fetchpriority="high" />
    <header id="header">
        <nav>
            <div id="logo">Abstraction</div>
            <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
            <div id="contact">
            <a href="#contact">Contact Us</a>
            </div>
        </nav>
    </header>
	<main id="mainContent">
        <p id="intro">Join Abstraction, Calvin’s Computer Science Club where you can
        gain hands on experience with Community Projects,
         Events, and Hackathons!<p>
        <img id="HomePageDesign" src={HomePageDesign.src} alt="" fetchpriority="high" />
	</main> 
</div>
 <div id="secondContent">
        <img id="HPGrayDesign" src={HPGrayDesign.src} alt="" fetchpriority="high" />
        <p id="mission">Abstraction is a student organization centered around computing and technology. Our goal is to build community among 
        students interested in computing and to serve others by providing a 
        space to have fun and to learn more about technology!<p>
</div>
<div id="card-container">
    <div class="card" id="card1">
        <h2>Community Projects</h2>
        <p id="card-subtext">Join our Community Projects where you work on a project mentored by a Calvin Professor. </p>
        <div class="learnmore-container">
            <p id="learnmore">Learn more</p>
            <img id="learnarrow" src={learnarrow.src} alt="" fetchpriority="high" />
        </div>
        <img id="card1design" src={card1design.src} alt="" fetchpriority="high" />
    </div>
    <div class="card" id="card2">
        <h2>Hackathon</h2>
        <p id="card-subtext">Join our annual 24 hour hackathon where you get the chance to gain $2000 + in prizes and credentials. </p>
         <div class="learnmore-container">
            <p id="learnmore">Learn more</p>
            <img id="learnarrow" src={learnarrow.src} alt="" fetchpriority="high" />
        </div>
        <img id="card2design" src={card2design.src} alt="" fetchpriority="high" />
        </div>
    <div class="card" id="card3">
        <h2>Workshops</h2>
        <p id="card-subtext">Explore the different workshops we offer such as resume building and networking sessions. </p>
         <div class="learnmore-container">
            <p id="learnmore">Learn more</p>
            <img id="learnarrow" src={learnarrow.src} alt="" fetchpriority="high" />
        </div>
        <img id="card1design" src={card1design.src} alt="" fetchpriority="high" />
    </div>
</div>

<style>
/* * {
    border: 1px solid blue !important;
}*/
	#MainBackground {
		position: absolute;
		top: 2em; /* Adding the margin at the top */
		left: 2em; /* Adding the margin on the left */
		width: calc(100% - 4em); /* Adjusting width to account for margin */
		height: calc(100% - 4em); /* Adjusting height to account for margin */
		object-fit: contain; /* Ensures the image scales nicely */
        z-index: -1;
	}

	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
		margin: 0;
		position: relative;
	}

    /* Header Navigation */

    #header {
    position: absolute;
    top: 2rem;
    left:3rem;
    width: calc(100% - 10rem);
    z-index: 1;
    padding: 1.5rem 2rem;
    }

    #header nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    }

    #header nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
    flex: 1;
    justify-content: center;
    }

    #header nav ul li a {
        color: #2537B7;
        text-decoration: none;
        font-size: 1.2rem;
        font-weight: 400;
        text-transform: uppercase;
        font-family: Helvetica, sans-serif;
        transition: color 0.3s ease;
    }

    #header nav ul li a:hover {
        color: #7F7FE2; /* Highlight color on hover */
    }

    #logo {
    color: #2537B7;
    font-size: 1.5rem;
    font-family: "quasimoda", sans-serif;
    font-weight: 800;
    font-style: normal;
    text-transform: uppercase;
    margin-right: auto;
    padding-left: 3rem;
}
    #contact {
        margin-left: auto;
        padding-right:3rem;
        list-style: none;
        font-family: Helvetica, sans-serif;
        font-weight: 400;
    }

    /* Main Content Styling */
    #mainContent {
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: absolute;
        top: -7rem;
        left: 0;
        width: auto;
        height: 100%;
        padding: 1rem;
        z-index: 1;
    }

    #intro {
        font-size: 2rem;
        font-family: "quasimoda", sans-serif;
        font-weight: 600;
        font-style: normal;
        color: #2537B7;
        max-width: 60%;
    }

    #HomePageDesign{
        position: absolute;
        top: 5rem;
        left: 0;
        width: 96.9%;
        height: 96.9%;
        object-fit: cover;
    }

    /* Second Content Styling */

    #secondContent{
        width: 100%;
        margin-top: -3rem;
        position: relative;
        display: flex; /* Enables flexbox */
        justify-content: center; /* Centers content horizontally */
        text-align: center; 
    }

    #HPGrayDesign{
        width: 100%;
        height: auto;
        position: absolute;
        object-fit: cover;
        left: -2em;
    }

    #mission {
        font-size: 2rem;
        font-family: "quasimoda", sans-serif;
        font-weight: 600;
        font-style: normal;
        color: #2537B7;
        max-width: 60%;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: absolute;
    }

    #card-container {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20rem;
    padding: 5rem;
    box-sizing: border-box;
    gap: 2rem;
    }

    .card {
    width: 350px;
    height: 350px;
    border-radius: 50px;
    background-color: #f0f0f0;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    display: flex; /* Use flexbox for card content layout */
    flex-direction: column; /* Stack elements vertically */
    justify-content: flex-start;
    padding: 2rem;
    }

    #card1{
        background-color: #E3EAFE;
        position:relative;
    }

     #card2{
        background-color: #FFE7CA;
        position:relative;
    }

     #card3{
        background-color: #E3EAFE;
        position:relative;
    }

    h2{
        color: #2537B7;
        font-family: "quasimoda", sans-serif;
        font-weight: 600;
        font-style: normal;
        position: relative; /* Position h2 absolutely inside card */
    }

    #card-subtext {
    font-family: "quasimoda", sans-serif;
    font-weight: 300;
    font-size: 20px;
    font-style: normal;
    color: #5E5E5E;
    }

    #learnmore{
    color: #2537B7;
    font-family: "quasimoda", sans-serif;
    font-weight: 500;
    font-size: 20px;
    }

    .learnmore-container {
    display: flex; /* Enables flexbox layout */
    align-items: center; /* Vertically centers items */
    gap: 0.5rem; /* Adds space between "Learn more" and the arrow */
    margin-top: -1rem; /* Optional: Adjust spacing from other content */
    height: 25px;
    }

    #learnarrow {
    width: 20px; /* Adjust the size of the arrow */
    height: auto;
    }

    #card1design{
    position: absolute; /* Enables absolute positioning */
    bottom: 22px; /* Aligns the image to the bottom */
    right: 29px; /* Aligns the image to the right */
    margin: 0; /* Removes any extra margin */
    transform: translate(10%, 10%); /* Optional: Adjust positioning slightly outside the edge */
    z-index: 1; /* Optional: Ensures it appears above other content, if needed */
    width: 300px; /* Adjust size as needed */
    height: auto;
    }
    #card2design{
    position: absolute; /* Enables absolute positioning */
    bottom: 19px; /* Aligns the image to the bottom */
    right: 20px; /* Aligns the image to the right */
    margin: 0; /* Removes any extra margin */
    transform: translate(10%, 10%); /* Optional: Adjust positioning slightly outside the edge */
    z-index: 1; /* Optional: Ensures it appears above other content, if needed */
    width: 220px; /* Adjust size as needed */
    height: auto;
    }

	@media screen and (max-height: 368px) {
		#news {
			display: none;
		}
	}

	@media screen and (max-width: 768px) {
		#container {
			display: flex;
			flex-direction: column;
		}

		#hero {
			display: block;
			padding-top: 10%;
		}

		#links {
			flex-wrap: wrap;
		}

		#links a.button {
			padding: 14px 18px;
		}

		#news {
			right: 16px;
			left: 16px;
			bottom: 2.5rem;
			max-width: 100%;
		}

		h1 {
			line-height: 1.5;
		}
	}
</style>